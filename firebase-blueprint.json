{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "A local cricket team participating in matches.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "description": "A cricket player belonging to a team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "stats": { "type": "object" }
      },
      "required": ["name", "teamId", "createdAt"]
    },
    "Match": {
      "title": "Match",
      "description": "A cricket match between two teams.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamAId": { "type": "string" },
        "teamBId": { "type": "string" },
        "teamAName": { "type": "string" },
        "teamBName": { "type": "string" },
        "tossWinnerId": { "type": "string" },
        "tossDecision": { "type": "string", "enum": ["bat", "bowl"] },
        "oversLimit": { "type": "number" },
        "status": { "type": "string", "enum": ["live", "completed", "abandoned"] },
        "winnerId": { "type": "string" },
        "margin": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currentInnings": { "type": "number" },
        "firstInnings": { "type": "object" },
        "secondInnings": { "type": "object" }
      },
      "required": ["teamAId", "teamBId", "tossWinnerId", "tossDecision", "oversLimit", "status", "createdAt", "currentInnings", "firstInnings"]
    }
  },
  "firestore": {
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Collection of local teams."
    },
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Collection of local players mapped to teams."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of live or finished matches."
    }
  }
}

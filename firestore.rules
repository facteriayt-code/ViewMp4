rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isIncomingValidTeam(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isIncomingValidPlayer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.teamId is string && data.teamId.size() > 0;
    }

    // Teams
    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isIncomingValidTeam(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Players
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isIncomingValidPlayer(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
